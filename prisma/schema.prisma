generator client {
  provider = "prisma-client"
  output   = "../prisma/generated"
}

datasource db {
  provider = "sqlite"
}

model TrackedNpub {
  id               Int       @id @default(autoincrement())
  npub             String    @unique
  pubkeyHex        String    @unique
  label            String?
  addedAt          DateTime  @default(now())
  lastFetchedAt    DateTime?
  cachedEventCount Int       @default(0)
  cachedCacheCount Int       @default(0)
  cachedProfile    String?   // JSON: NostrProfile
  statsComputedAt  DateTime?
}

model NostrEvent {
  id        Int      @id @default(autoincrement())
  eventId   String   @unique
  pubkeyHex String
  kind      Int
  content   String
  tags      String
  sig       String
  createdAt Int
  fetchedAt DateTime @default(now())
  source    String
  sourceRelay Relay  @relation(fields: [source], references: [url])

  @@index([pubkeyHex])
  @@index([kind])
  @@index([pubkeyHex, kind])
  @@index([createdAt])
}

model EventSource {
  id      Int      @id @default(autoincrement())
  eventId String
  relay   String
  seenAt  DateTime @default(now())
  relayRef Relay   @relation(fields: [relay], references: [url])

  @@unique([eventId, relay])
  @@index([relay])
  @@index([eventId])
}

model Relay {
  id                Int            @id @default(autoincrement())
  url               String         @unique
  firstSeenAt       DateTime       @default(now())
  consecutiveErrors Int            @default(0)
  lastErrorAt       DateTime?
  backoffUntil      DateTime?
  nostrEvents       NostrEvent[]
  eventSources      EventSource[]
  relayChecks       RelayCheck[]
}

model RelayCheck {
  id            Int      @id @default(autoincrement())
  relay         String
  status        String   // "ok" | "error"
  latencyMs     Int?     // ms to connect, null if failed
  error         String?  // error message if failed
  errorCategory String?  // classified error type
  checkedAt     DateTime @default(now())
  relayRef      Relay    @relation(fields: [relay], references: [url])

  @@index([relay, checkedAt])
  @@index([checkedAt])
  @@index([relay, errorCategory])
}

model TimezoneEstimate {
  id                  Int      @id @default(autoincrement())
  pubkeyHex           String   @unique
  estimatedUtcOffset  Float
  confidence          String   // "low" | "medium" | "high"
  activityPeakUtc     Float
  eventCount          Int
  daySpread           Int
  stddevHours         Float
  flaggedUnreliable   Boolean  @default(false)
  lastComputedAt      DateTime @default(now())
}

model PubkeyStats {
  id                Int      @id @default(autoincrement())
  pubkeyHex         String   @unique
  kindDistribution  String   // JSON: [{kind, count}]
  relayDistribution String   // JSON: [{relay, count}]
  totalEvents       Int
  earliestEvent     Int
  latestEvent       Int
  computedAt        DateTime @default(now())
}

model RelaySnapshot {
  id         Int      @id @default(autoincrement())
  relay      String   @unique
  uptime24h  Float?
  uptime7d   Float?
  eventCount Int      @default(0)
  computedAt DateTime @default(now())
}

model GlobalStats {
  id                  Int      @id @default(1)
  totalEvents         Int      @default(0)
  totalCacheResponses Int      @default(0)
  computedAt          DateTime @default(now())
}

model CacheResponse {
  id           Int      @id @default(autoincrement())
  pubkeyHex    String
  queryType    String
  responseKind Int
  content      String
  fetchedAt    DateTime @default(now()) @updatedAt

  @@unique([pubkeyHex, queryType, responseKind])
  @@index([pubkeyHex])
  @@index([queryType])
  @@index([pubkeyHex, queryType])
}
