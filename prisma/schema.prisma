generator client {
  provider = "prisma-client"
  output   = "../prisma/generated"
}

datasource db {
  provider = "sqlite"
}

model TrackedNpub {
  id            Int       @id @default(autoincrement())
  npub          String    @unique
  pubkeyHex     String    @unique
  label         String?
  addedAt       DateTime  @default(now())
  lastFetchedAt DateTime?
}

model NostrEvent {
  id        Int      @id @default(autoincrement())
  eventId   String   @unique
  pubkeyHex String
  kind      Int
  content   String
  tags      String
  sig       String
  createdAt Int
  fetchedAt DateTime @default(now())
  source    String

  @@index([pubkeyHex])
  @@index([kind])
  @@index([pubkeyHex, kind])
  @@index([createdAt])
}

model EventSource {
  id      Int      @id @default(autoincrement())
  eventId String
  relay   String
  seenAt  DateTime @default(now())

  @@unique([eventId, relay])
  @@index([relay])
  @@index([eventId])
}

model Relay {
  id                Int       @id @default(autoincrement())
  url               String    @unique
  firstSeenAt       DateTime  @default(now())
  consecutiveErrors Int       @default(0)
  lastErrorAt       DateTime?
  backoffUntil      DateTime?
}

model RelayCheck {
  id            Int      @id @default(autoincrement())
  relay         String
  status        String   // "ok" | "error"
  latencyMs     Int?     // ms to connect, null if failed
  error         String?  // error message if failed
  errorCategory String?  // classified error type
  checkedAt     DateTime @default(now())

  @@index([relay, checkedAt])
  @@index([checkedAt])
  @@index([relay, errorCategory])
}

model CacheResponse {
  id           Int      @id @default(autoincrement())
  pubkeyHex    String
  queryType    String
  responseKind Int
  content      String
  fetchedAt    DateTime @default(now()) @updatedAt

  @@unique([pubkeyHex, queryType, responseKind])
  @@index([pubkeyHex])
  @@index([queryType])
  @@index([pubkeyHex, queryType])
}
